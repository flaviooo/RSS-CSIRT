{
  "name": "cve-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cron": "tsx scripts/cron-job.ts",
    "pm2StartDashboard": "npm run build && pm2 start npm --name Dashboard --output log/DashboardOut.log --error log/DashboardErr.log --time -- run start -- -p 3006",
    "pm2Cron": "pm2 start npm --name DashboardCron --output log/CronOut.log --error log/CronErr.log --time -- run cron",
    "pm2Start": "npm run build && pm2 start ecosystem.config.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^17.3.1",
    "mongoose": "^8.12.0",
    "next": "^15.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
